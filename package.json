{
  "name": "community-demand-collector",
  "version": "1.0.0",
  "description": "CLI tool to collect user demands from various communities",
  "main": "dist/index.js",
  "bin": {
    "demand-collector": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "ts-node src/test.ts",
    "test:reddit": "ts-node src/test-reddit.ts",
    "test:twitter": "ts-node src/test-twitter.ts",
    "test:all": "ts-node src/test-all.ts",
    "pkg": "pkg dist/index.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output dist/demand-collector"
  },
  "keywords": [
    "cli",
    "community",
    "demand",
    "collector"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@demand-collector/core": "file:packages/core",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "playwright": "^1.58.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
